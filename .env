# =============================================================================
# ETL FILES - PRODUCTION CONFIGURATION (Thread Safety & Parallel Execution)
# =============================================================================

# Number of parallel download workers (for 64GB RAM: 8 recommended)
ETL_PARALLEL_WORKERS=8

# Max memory per ETL process (GB) - out of 64GB total, reserve 14GB for OS
ETL_MAX_MEMORY_GB=50

# Database connection pool size (should be >= workers + 2)
ETL_DB_POOL_SIZE=10

# File locking for thread-safe concurrent writes
ENABLE_FILE_LOCKING=true
FILES_LOCK_TIMEOUT=60

# Memory monitoring and alerts
ENABLE_MEMORY_MONITORING=true
MEMORY_CHECK_INTERVAL_SECONDS=30
MEMORY_ALERT_THRESHOLD_PERCENT=85

# Batch size for processing
ETL_BATCH_SIZE=100

# File download timeout
FILES_DOWNLOAD_TIMEOUT=180

# Retry configuration
FILES_MAX_RETRIES=5

# Delay between consecutive operations



# MongoDB (etl-mongo-to-postgresql)
MONGO_URI=mongodb://192.168.103.112:27017/
MONGO_DB_NAME=dopamas_old_data_db
MONGO_COLLECTION_NAME=fir_records

# Deduplication agent
CACHE_BACKEND=redis
JWT_SECRET=supersecretkey
JWT_ALGORITHM=HS256
RDS_USER=dev_dopamas
RDS_PASS=ADevingpjveD2rkdoast4s
RDS_DB=dev-3
RDS_HOST=192.168.103.106
RDS_PORT=5432
REDIS_URL=redis://default:dopams_5982!@192.168.103.106:6379/0

# Application
DEBUG=True
LOG_LEVEL=INFO

# ETL Tuning (used by all ETL config modules)
CHUNK_OVERLAP_DAYS=1

# Parallel LLM workers for brief_facts_drugs pipeline
# Must match Ollama's OLLAMA_NUM_PARALLEL setting on the server.
# VRAM guide for qwen2.5-coder:14b @ num_ctx=16384:
#   24GB → 3, 48GB → 6, 80GB → 10
PARALLEL_LLM_WORKERS=3
ENABLE_EMBEDDINGS=false
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Comma-separated list of APIs to process; empty = process all
# Valid values: crimes,persons,property,interrogation,mo_seizures,chargesheets,fsl_case_property
ETL_PROCESS_APIS=

# DB keepalive / timeout (used by etl_fsl_case_property, etl_updated_chargesheet)
DB_CONNECT_TIMEOUT=10
DB_KEEPALIVES=1
DB_KEEPALIVES_IDLE=30
DB_KEEPALIVES_INTERVAL=10
DB_KEEPALIVES_COUNT=5

# Superuser credentials (used by etl_refresh_views/grant_privileges_helper.py)
SUPERUSER_DB_USER=dev_dopamas
SUPERUSER_DB_PASSWORD=ADevingpjveD2rkdoast4s

# Drug standardization
FUZZY_THRESHOLD=0.4

# Files ETL retry tuning
FILES_RETRY_DELAY_SECONDS=1.0
FILES_PER_FILE_SLEEP_SECONDS=1.0

